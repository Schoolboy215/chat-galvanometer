<Window x:Class="ChatGalvanometer.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add word" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MinWidth="240">
    <StackPanel Margin="12">
        <TextBlock x:Name="PromptText" Margin="0,0,0,6"/>
        <TextBox x:Name="InputBox" Margin="0,0,0,10" MinWidth="200"
                 KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Margin="0,0,6,0" IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="70" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
