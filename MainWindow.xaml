<Window x:Class="ChatGalvanometer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatGalvanometer"
        mc:Ignorable="d"
        Title="Chat Galvanometer" Height="520" Width="680" MinHeight="480" MinWidth="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Left column -->
        <StackPanel Grid.Column="0" Margin="8" VerticalAlignment="Top">

            <GroupBox Header="Authentication" Margin="0,0,0,6">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client Id" VerticalAlignment="Center" Margin="0,0,8,4"/>
                    <TextBox x:Name="clientIdBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                             Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Token" VerticalAlignment="Center" Margin="0,0,8,4"/>
                    <TextBox x:Name="tokenBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                             Text="{Binding BearerToken, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="False"
                             Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"
                             FontFamily="OpenSymbol"/>

                    <Button x:Name="getTokenButton" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="Get Token" HorizontalAlignment="Left" Width="80"
                            Click="getTokenButton_Click"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Users" Margin="0,0,0,6">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Your username" Margin="0,0,4,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Your user Id" Margin="0,0,4,2"/>

                    <TextBox x:Name="userNameBox" Grid.Row="1" Grid.Column="0" Margin="0,0,4,6"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="UserIdBox" Grid.Row="1" Grid.Column="1" Margin="0,0,4,6"
                             IsEnabled="False"
                             Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"
                             Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="UserIdLookupButton" Grid.Row="1" Grid.Column="2"
                            Content="Lookup" Margin="0,0,0,6"
                            IsEnabled="{Binding UserIdLookupEnabled, UpdateSourceTrigger=PropertyChanged}"
                            Click="UserIdLookupButton_Click"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Broadcaster username" Margin="0,0,4,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Broadcaster Id" Margin="0,0,4,2"/>

                    <TextBox x:Name="BroadcasterNameBox" Grid.Row="3" Grid.Column="0" Margin="0,0,4,0"
                             Text="{Binding BroadcasterName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox x:Name="BroadcasterIdBox" Grid.Row="3" Grid.Column="1" Margin="0,0,4,0"
                             IsEnabled="False"
                             Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"
                             Text="{Binding BroadcasterId, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BroadcasterIdLookup" Grid.Row="3" Grid.Column="2"
                            Content="Lookup"
                            IsEnabled="{Binding BroadcasterIdLookupEnabled, UpdateSourceTrigger=PropertyChanged}"
                            Click="BroadcasterIdLookup_Click"/>
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#cc3333"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#33aa33"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatusText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="connectButton" Width="80"
                        IsEnabled="{Binding ConnectButtonEnabled}" Click="connectButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="Connect"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Content" Value="Disconnect"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <GroupBox Header="Tuning" Margin="0,0,0,6">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="Evaluation window (seconds)" Margin="0,0,0,2"/>
                    <TextBox x:Name="WindowLengthBox" Grid.Row="1" Grid.Column="0" Margin="0,0,4,6"
                             Text="{Binding EvaluationWindowLength, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="Sensitivity (how much does it take to max out the scale)" Margin="0,0,0,2"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="MaxSentimentBox" Grid.Row="3" Grid.Column="0" Margin="0,0,4,6"
                             Text="{Binding MaxSentiment, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock x:Name="PercentSentDebug" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding PercentSentiment, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Replay" Margin="0,0,0,0">
                <StackPanel Margin="4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="replayFilePickerButton" Content="Choose file" Margin="0,0,6,0"
                                Click="replayFilePickerButton_Click"/>
                        <TextBox x:Name="replayFileNameBox" Width="160" VerticalAlignment="Center"
                                 IsEnabled="False"
                                 Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Start time" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="startTimeBox" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- Right column -->
        <StackPanel Grid.Column="1" Margin="0,8,8,8" VerticalAlignment="Top">

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="BadListLabel" Grid.Row="0" Grid.Column="0" Text="Bad" Margin="0,0,0,2"/>
                <TextBlock x:Name="GoodListLabel" Grid.Row="0" Grid.Column="1" Text="Good" Margin="4,0,0,2"/>

                <ListView x:Name="BadList" Grid.Row="1" Grid.Column="0" Margin="0,0,2,0"
                          d:ItemsSource="{d:SampleData ItemCount=5}"
                          ItemsSource="{Binding BadItems, UpdateSourceTrigger=PropertyChanged}">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Template" Value="{x:Null}"/>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <ListView x:Name="GoodList" Grid.Row="1" Grid.Column="1" Margin="2,0,0,0"
                          d:ItemsSource="{d:SampleData ItemCount=5}"
                          ItemsSource="{Binding GoodItems, UpdateSourceTrigger=PropertyChanged}">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Template" Value="{x:Null}"/>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <GroupBox Header="COM Port">
                <StackPanel Margin="4">
                    <ListView x:Name="COMList" Height="120" Margin="0,0,0,4"
                              d:ItemsSource="{d:SampleData ItemCount=5}"
                              ItemsSource="{Binding COMPorts, UpdateSourceTrigger=PropertyChanged}"
                              SelectionChanged="COMList_SelectionChanged"
                              SelectionMode="Single">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Template" Value="{x:Null}"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button x:Name="COMTestButton" Content="Test" HorizontalAlignment="Left" Width="60"
                            Click="COMTestButton_Click"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </Grid>
</Window>
